# Otyokwah - Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.

# --- GitHub / Keystatic CMS ---
GITHUB_OWNER=your-github-org
GITHUB_REPO=your-repo-name
GITHUB_TOKEN=your-github-token-here
KEYSTATIC_GITHUB_CLIENT_ID=your-keystatic-github-client-id
KEYSTATIC_GITHUB_CLIENT_SECRET=your-keystatic-github-client-secret
KEYSTATIC_SECRET=your-keystatic-secret
KEYSTATIC_GITHUB_TOKEN=your-keystatic-github-token
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=your-app-slug

# --- Site URLs ---
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com
PRODUCTION_DOMAIN=your-domain.com
PRODUCTION_URL=https://your-domain.com
E2E_BASE_URL=http://localhost:3000

# --- API Secrets ---
REVALIDATE_SECRET=your-revalidate-secret
DRAFT_SECRET=your-draft-secret

# --- Vercel ---
VERCEL_TOKEN=your-vercel-token
VERCEL_PROJECT_ID=your-vercel-project-id

# --- Email / SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_FORM_TO=info@otyokwah.org
CONTACT_FORM_FROM=your-email@gmail.com
CONTACT_EMAIL=info@otyokwah.org
REGISTRAR_EMAIL=registrar@otyokwah.org

# --- Cloudflare Turnstile (CAPTCHA) ---
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# --- AI / LLM ---
UNIVERSAL_LLM_KEY=your-llm-api-key

# --- Bug Reporting (GitHub Issues) ---
GITHUB_REPO_OWNER=your-github-org
GITHUB_REPO_NAME=your-repo-name

# --- Feature Flags ---
NEXT_PUBLIC_ENABLE_LIVE_PREVIEW=false

# --- Analytics ---
# Get this from your Google Analytics 4 property (Measurement ID, format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# --- UltraCamp Registration ---
# API key from your UltraCamp account settings
ULTRACAMP_API_KEY=your-ultracamp-api-key

# --- Content ---
NEXT_PUBLIC_TESTIMONIAL_VIDEO_ID=your-youtube-video-id

# --- Testing (E2E only, not needed for dev) ---
# GITHUB_TEST_USER=your-test-github-username
# GITHUB_TEST_PASS=your-test-github-password
# VISUAL_PROOF_ENABLED=false
