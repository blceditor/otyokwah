# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
.env.verify
*.bak
.env*.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tina
.tina/__generated__

# smoke test cache and logs
.cache/smoke/
.cache/autofix/
logs/smoke/

# playwright e2e tests
tests/e2e/.auth/
tests/e2e/screenshots/
tests/e2e/results/
playwright-report/
test-results/
.env.production

# visual proof screenshots (REQ-PROC-004)
# Keep directory structure but ignore images
verification-screenshots/*.png
verification-screenshots/*.meta.json
verification-screenshots/manifest.json
verification-screenshots/visual-proof-report.json
# Keep .last-run.json for tracking
!verification-screenshots/.last-run.json
